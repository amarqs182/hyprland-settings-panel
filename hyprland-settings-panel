class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        pass
    
    def do_GET(self):
        if self.path == '/' or self.path == '/index.html':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html')
            self.end_headers()
            
            theme_styles = get_theme_styles()
            if theme_styles:
                resp = HTML.replace("/* THEME_VARIABLES */", theme_styles)
            else:
                default_root = """
:root {
  --bg: #111111;
  --bg2: #1a1a1a;
  --bg3: #222222;
  --bg4: #2a2a2a;
  --fg: #e0e0e0;
  --fg2: #888888;
  --fg3: #555555;
  --accent: #F5B700;
  --accent2: #7A5C00;
  --accent3: #3d2e00;
  --border: #2a2a2a;
  --border2: #333333;
  --hover: #2a2a2a;
  --active: #333333;
  --success: #4ade80;
  --danger: #f87171;
  --radius: 6px;
  --radius2: 10px;
  --shadow: 0 2px 8px rgba(0,0,0,0.3);
  --transition: 0.15s ease;
}
"""
                resp = HTML.replace("/* THEME_VARIABLES */", default_root)
            self.wfile.write(resp.encode())
        else:
            self.send_error(404)
    
    def do_POST(self):
        if self.path == '/api':
            length = int(self.headers.get('Content-Length', 0))
            body = json.loads(self.rfile.read(length))
            
            action = body.get('action')
            opt = body.get('opt')
            value = body.get('value')
            
            if action == 'get':
                result = get_option(opt)
            elif action == 'get_version':
                result = {"value": get_hyprland_version()}
            elif action == 'set':
                set_option(opt, value)
                result = {"ok": True}
            else:
                result = {"error": "unknown action"}
            
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            self.wfile.write(json.dumps(result).encode())
        elif self.path == '/api/system':
            length = int(self.headers.get('Content-Length', 0))
            body = json.loads(self.rfile.read(length))
            action = body.get('action')
            
            if action == 'get_locale':
                try:
                    loc = subprocess.run(['localectl', 'status'], capture_output=True, text=True, timeout=5)
                    lines = loc.stdout.strip().split('\n')
                    result = {}
                    for line in lines:
                        if 'LANG=' in line:
                            result['system_lang'] = line.split('LANG=')[1].strip()
                        if 'VC Keymap:' in line:
                            result['vc_keymap'] = line.split('VC Keymap:')[1].strip()
                        if 'X11 Layout:' in line:
                            result['x11_layout'] = line.split('X11 Layout:')[1].strip()
                    if not result.get('system_lang'):
                        result['system_lang'] = os.environ.get('LANG', 'unknown')
                except:
                    result = {'system_lang': os.environ.get('LANG', 'unknown'), 'vc_keymap': '?', 'x11_layout': '?'}
            elif action == 'set_locale':
                locale = body.get('locale', '')
                try:
                    subprocess.run(['localectl', 'set-locale', f'LANG={locale}'], capture_output=True, text=True, timeout=10)
                    result = {"ok": True}
                except Exception as e:
                    result = {"ok": False, "error": str(e)}
            else:
                result = {"error": "unknown system action"}
            
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            self.wfile.write(json.dumps(result).encode())
        else:
            self.send_error(404)

def is_port_in_use(port):
    import socket
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        return s.connect_ex(('127.0.0.1', port)) == 0

def open_panel():
    import shutil
    url = f"http://127.0.0.1:{PORT}"
    try:
        if shutil.which("omarchy-launch-webapp"):
            subprocess.Popen(["omarchy-launch-webapp", url])
            return
        for browser in ["chromium", "google-chrome", "brave-browser", "vivaldi-stable", "chrome"]:
            if shutil.which(browser):
                subprocess.Popen([browser, f"--app={url}"])
                return
    except Exception as e:
        print(f"Error launching web app: {e}")
    webbrowser.open(url)

def main():
    # If already running (e.g. systemd service), just open browser
    if is_port_in_use(PORT):
        open_panel()
        return
    
    server = http.server.HTTPServer(('127.0.0.1', PORT), Handler)
    print(f"Hyprland Settings Panel: http://127.0.0.1:{PORT}")
    
    # Handle SIGTERM for clean systemd shutdowns
    def handle_sigterm(signum, frame):
        print("Received SIGTERM, shutting down...")
        server.shutdown()
        sys.exit(0)
    signal.signal(signal.SIGTERM, handle_sigterm)
    
    threading.Timer(0.5, open_panel).start()
    
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nClosing...")
        server.shutdown()

if __name__ == '__main__':
    main()
