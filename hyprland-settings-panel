        <input type="range" min="${min}" max="${max}" step="${step}" value="${data.value}"
               oninput="this.parentElement.querySelector('.current-value').textContent=this.value"
               onchange="setOpt('${opt}', this.value)">
        <span class="current-value">${data.value}</span>
        <input type="number" min="${min}" max="${max}" step="${step}" value="${data.value}"
               onchange="setOpt('${opt}', this.value); this.previousElementSibling.previousElementSibling.value=this.value">
      </div>
      ${desc ? `<div style="font-size:10px;color:var(--fg3);margin-top:6px">${desc}</div>` : ''}
    </div>
  `);
}

function makeSelect(opt, label, options, desc) {
  return getOpt(opt).then(data => `
    <div class="setting-card">
      <div class="header">
        <div class="label">${label}</div>
        <div class="opt-name">${opt}</div>
      </div>
      <div class="value-row">
        <select onchange="setOpt('${opt}', this.value)">
          ${options.map(o => `<option value="${o}" ${data.value === o ? 'selected' : ''}>${o}</option>`).join('')}
        </select>
      </div>
      ${desc ? `<div style="font-size:10px;color:var(--fg3);margin-top:6px">${desc}</div>` : ''}
    </div>
  `);
}

function makeText(opt, label, desc) {
  return getOpt(opt).then(data => {
    const isColor = opt.includes('col.') || opt.includes('color');
    const colorPreview = isColor ? parseHyprlandColor(data.value) : null;
    const previewStyle = colorPreview ? `background: ${colorPreview}; border: 1px solid var(--border2); width: 20px; height: 20px; border-radius: 4px; display: inline-block;` : 'display: none;';
    
    return `
      <div class="setting-card">
        <div class="header">
          <div class="label">${label}</div>
          <div class="opt-name">${opt}</div>
        </div>
        <div class="value-row">
          <span class="color-preview" style="${previewStyle}"></span>
          <input type="text" value="${data.value || ''}" placeholder="..."
                 oninput="if(this.parentElement.querySelector('.color-preview')) { const c = parseHyprlandColor(this.value); if(c) { this.parentElement.querySelector('.color-preview').style.background = c; this.parentElement.querySelector('.color-preview').style.display = 'inline-block'; } else { this.parentElement.querySelector('.color-preview').style.display = 'none'; } }"
                 onchange="setOpt('${opt}', this.value)">
        </div>
        ${desc ? `<div style="font-size:10px;color:var(--fg3);margin-top:6px">${desc}</div>` : ''}
      </div>
    `;
  });
}

