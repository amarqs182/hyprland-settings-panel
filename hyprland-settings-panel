    """
    return css

def dict_to_hyprland_config(flat_dict):
    nested = {}
    for key, val in flat_dict.items():
        parts = key.replace('.', ':').split(':')
        d = nested
        for part in parts[:-1]:
            d = d.setdefault(part, {})
        d[parts[-1]] = val
    
    def serialize(d, indent=0):
        lines = []
        pad = "  " * indent
        for k, v in sorted(d.items()):
            if isinstance(v, dict):
                lines.append(f"{pad}{k} {{")
                lines.extend(serialize(v, indent + 1))
                lines.append(f"{pad}}}")
            else:
                if isinstance(v, bool):
                    val_str = "true" if v else "false"
                elif v is None:
                    continue
                else:
                    val_str = str(v)
                lines.append(f"{pad}{k} = {val_str}")
        return lines
    
    return "\n".join(serialize(nested))

def dict_to_lua_config(flat_dict):
    """Convert flat settings dict to Hyprland Lua config format."""
    nested = {}
    for key, val in flat_dict.items():
        parts = key.replace('.', ':').split(':')
        d = nested
        for part in parts[:-1]:
            d = d.setdefault(part, {})
        d[parts[-1]] = val

    def lua_value(v):
        if isinstance(v, bool):
            return "true" if v else "false"
        if isinstance(v, (int, float)):
            return str(v)
        if isinstance(v, str):
            # Check if it looks like a number
            try:
                float(v)
                return v
            except ValueError:
                pass
            # Escape quotes
            return f'"{v}"'
        return str(v)

    def serialize(d, indent=1):
        lines = []
        pad = "  " * indent
        for k, v in sorted(d.items()):
            key = k.replace('.', '_').replace('-', '_')
            if isinstance(v, dict):
                lines.append(f"{pad}{key} = {{")
                lines.extend(serialize(v, indent + 1))
                lines.append(f"{pad}}},")
            else:
                lines.append(f"{pad}{key} = {lua_value(v)},")
        return lines

    lines = ["-- Generated by Hyprland Settings Panel", "-- Do not edit manually!", "", "hl.config({", "  -- Window rules for Visual Settings App", "  windowrule = {", "    { "float on", match = { title = "^(Hyprland Settings)$" } },", "    { "size 1024 720", match = { title = "^(Hyprland Settings)$" } },", "    { "center on", match = { title = "^(Hyprland Settings)$" } },", "  },", ""]
    lines.extend(serialize(nested))
    lines.append("})")
    return "\n".join(lines)

def get_hyprland_version_int():
    """Return major version number (e.g. 55 for 0.55.x)."""
    try:
        result = subprocess.run(['hyprctl', 'version', '-j'], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            data = json.loads(result.stdout)
            tag = data.get('tag', '0.0').lstrip('v')
            parts = tag.split('.')
            if len(parts) >= 2:
                return int(parts[1])
    except:
        pass
    return 0

def is_lua_config():
    """Check if Hyprland is using Lua config (0.55+)."""
    return get_hyprland_version_int() >= 55

def ensure_source_in_hyprland_conf():
    conf_source = "source = ~/.config/hypr/user-settings.conf"
    lua_require = 'require("user-settings")'
    try:
        if os.path.exists(HYPRLAND_CONF):
            with open(HYPRLAND_CONF, 'r') as f:
                content = f.read()

            if is_lua_config():
                # Lua mode: add require, remove old conf source
                if lua_require not in content:
                    with open(HYPRLAND_CONF, 'a') as f:
                        f.write(f"\n\n-- Sourced settings from Hyprland Settings Panel\n{lua_require}\n")
            else:
                # Hyprlang mode: add source
                if conf_source not in content:
                    with open(HYPRLAND_CONF, 'a') as f:
                        f.write(f"\n\n# Sourced settings from Hyprland Settings Panel\n{conf_source}\n")
    except Exception as e:
        print(f"Error updating hyprland.conf: {e}")

def set_option(opt, value):
    if isinstance(value, bool):
        val_str = "true" if value else "false"
    else:
        val_str = str(value)
    hyprctl(f"keyword {opt} {val_str}")
    
    try:
        os.makedirs(USER_SETTINGS_DIR, exist_ok=True)
        if os.path.exists(USER_SETTINGS_JSON):
            with open(USER_SETTINGS_JSON, 'r') as f:
                settings = json.load(f)
        else:
            settings = {}
            
        settings[opt] = value
        
        with open(USER_SETTINGS_JSON, 'w') as f:
            json.dump(settings, f, indent=2)
            
        # Generate hyprlang config (.conf)
        nested_conf = dict_to_hyprland_config(settings)
        window_rules = (
            "\n# Window rules for Visual Settings App\n"
            "windowrule = float on, match:title ^(Hyprland Settings)$\n"
            "windowrule = size 1024 720, match:title ^(Hyprland Settings)$\n"
            "windowrule = center on, match:title ^(Hyprland Settings)$\n"
        )
        with open(USER_SETTINGS_CONF, 'w') as f:
            f.write("# Generated by Hyprland Settings Panel\n# Do not edit manually!\n\n" + nested_conf + "\n" + window_rules + "\n")

        # Generate Lua config (.lua) for Hyprland 0.55+
        if is_lua_config():
            lua_path = os.path.join(USER_SETTINGS_DIR, "user-settings.lua")
            lua_content = dict_to_lua_config(settings)
            with open(lua_path, 'w') as f:
                f.write(lua_content)
            
        ensure_source_in_hyprland_conf()
    except Exception as e:
        print(f"Error saving setting {opt}: {e}")


