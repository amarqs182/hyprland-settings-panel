    case 'debug': renderDebug(main); break;
    case 'presets': renderPresets(main); break;
    case 'locale': renderLocale(main); break;
  }
}

function filterSettings(query) {
  const q = query.toLowerCase();
  document.querySelectorAll('.setting-card').forEach(card => {
    const label = (card.querySelector('.label')?.textContent || '').toLowerCase();
    const optName = (card.querySelector('.opt-name')?.textContent || '').toLowerCase();
    if (label.includes(q) || optName.includes(q)) {
      card.style.display = '';
    } else {
      card.style.display = 'none';
    }
  });
}

function parseHyprlandColor(val) {
  if (!val) return null;
  val = val.trim();
  if (val.startsWith('0x')) {
    let hex = val.substring(2);
    if (hex.length === 8) {
      let a = parseInt(hex.substring(0, 2), 16) / 255;
      let r = parseInt(hex.substring(2, 4), 16);
      let g = parseInt(hex.substring(4, 6), 16);
      let b = parseInt(hex.substring(6, 8), 16);
      return `rgba(${r}, ${g}, ${b}, ${a})`;
    } else if (hex.length === 6) {
      return `#${hex}`;
    }
  }
  const rgbaMatch = val.match(/rgba\(([0-9a-fA-F]{8})\)/);
  if (rgbaMatch) {
    let hex = rgbaMatch[1];
    let r = parseInt(hex.substring(0, 2), 16);
    let g = parseInt(hex.substring(2, 4), 16);
    let b = parseInt(hex.substring(4, 6), 16);
    let a = parseInt(hex.substring(6, 8), 16) / 255;
    return `rgba(${r}, ${g}, ${b}, ${a})`;
  }
  const rgbMatch = val.match(/rgb\(([0-9a-fA-F]{6})\)/);
  if (rgbMatch) {
    return `#${rgbMatch[1]}`;
  }
  if (val.includes(' ')) {
    let parts = val.split(/\s+/);
    let first = parseHyprlandColor(parts[0]);
    if (first) return first;
  }
  return null;
}

function makeToggle(opt, label, desc) {
  return getOpt(opt).then(data => `
    <div class="setting-card">
