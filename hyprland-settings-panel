  // Garantir classe active na sidebar se houver evento de clique
  if (window.event && window.event.target) {
    const item = window.event.target.closest('.sidebar-item');
    if (item) item.classList.add('active');
  }
  
  const main = document.getElementById('main-content');
  switch(name) {
    case 'general': renderGeneral(main); break;
    case 'decoration': renderDecoration(main); break;
    case 'animations': renderAnimations(main); break;
    case 'group': renderGroup(main); break;
    case 'dwindle': renderDwindle(main); break;
