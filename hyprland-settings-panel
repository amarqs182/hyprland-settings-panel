        <div class="opt-name">${opt}</div>
      </div>
      <div class="value-row">
        <label class="toggle">
          <input type="checkbox" ${data.value ? 'checked' : ''} 
                 onchange="setOpt('${opt}', this.checked); this.closest('.setting-card').querySelector('.current-value').textContent = this.checked ? 'ON' : 'OFF'">
          <span class="slider"></span>
        </label>
        <span class="current-value">${data.value ? 'ON' : 'OFF'}</span>
        ${desc ? `<span style="font-size:11px;color:var(--fg3);margin-left:auto">${desc}</span>` : ''}
      </div>
    </div>
  `);
}

function makeSlider(opt, label, min, max, step, desc) {
  return getOpt(opt).then(data => `
    <div class="setting-card">
      <div class="header">
