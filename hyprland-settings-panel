def parse_colors_toml(path):
    colors = {}
    try:
        with open(path, "r") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#"):
                    continue
                if "=" in line:
                    parts = line.split("=", 1)
                    k = parts[0].strip()
                    v = parts[1].strip().strip('"').strip("'")
                    colors[k] = v
    except Exception as e:
        print(f"Error parsing colors.toml: {e}")
    return colors

def get_hyprland_version():
    try:
        result = subprocess.run(['hyprctl', 'version', '-j'], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            data = json.loads(result.stdout)
            tag = data.get('tag', 'unknown')
            return tag.lstrip('v')
    except:
        pass
    return 'unknown'

def get_theme_styles():
    theme_name = "catppuccin"
