        result = subprocess.run(["omarchy", "theme", "current"], capture_output=True, text=True, timeout=2)
        if result.returncode == 0:
            theme_name = result.stdout.strip()
    except Exception as e:
        print(f"Error getting theme name: {e}")

    colors = None
    name_lower = theme_name.lower()
    paths = [
        os.path.expanduser(f"~/.config/omarchy/themes/{name_lower}/colors.toml"),
        os.path.expanduser(f"~/.local/share/omarchy/themes/{name_lower}/colors.toml"),
        os.path.expanduser(f"~/.config/omarchy/themes/{theme_name}/colors.toml"),
        os.path.expanduser(f"~/.local/share/omarchy/themes/{theme_name}/colors.toml"),
    ]
    for path in paths:
        if os.path.exists(path):
            colors = parse_colors_toml(path)
            break

    if not colors:
        return ""

    bg = colors.get("background", "#111111")
    fg = colors.get("foreground", "#e0e0e0")
    accent = colors.get("accent", "#F5B700")
    
    bg2 = colors.get("surface_2", colors.get("surface", bg))
    bg3 = colors.get("surface", bg2)
    bg4 = colors.get("selection_background", bg3)
    
    border = colors.get("border", "#2a2a2a")
    border2 = colors.get("soft_border", border)
    
    hover = colors.get("hover_surface", bg2)
    active = colors.get("selection_background", bg3)
    
    success = colors.get("success", "#4ade80")
    danger = colors.get("danger", "#f87171")
    
    is_light = False
    for p in paths:
        d = os.path.dirname(p)
        if os.path.exists(d) and os.path.isdir(d):
            if os.path.exists(os.path.join(d, "light.mode")):
                is_light = True
                break
    
    if not is_light:
        try:
            hex_val = bg.lstrip('#')
            r, g, b = int(hex_val[0:2], 16), int(hex_val[2:4], 16), int(hex_val[4:6], 16)
            brightness = (r * 299 + g * 587 + b * 114) / 1000
            if brightness > 128:
                is_light = True
        except:
            pass

    if is_light:
        fg2 = colors.get("muted", "#666666")
        fg3 = "#888888"
        accent2 = accent
        accent3 = "#FEF3C7"
        shadow = "rgba(0,0,0,0.06)"
    else:
